# ============================================================
# FreightForce — local development environment.
# Copy to .env and adjust per developer.
# .env is gitignored — never commit real credentials.
# ============================================================

# ----- General -----
ENV=development
LOG_LEVEL=debug
SERVICE_DOMAIN=localhost

# ----- PostgreSQL (transactional: orders, bookings, contracts) -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=freightforce
POSTGRES_PASSWORD=freightforce
POSTGRES_DB=freightforce

# ----- TimescaleDB (telematics, temperature traces) -----
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5433
TIMESCALE_USER=freightforce
TIMESCALE_PASSWORD=freightforce
TIMESCALE_DB=telematics

# ----- MongoDB (POD images, customs declarations, EDI envelopes) -----
MONGO_URI=mongodb://localhost:27017
MONGO_DB=freightforce

# ----- Cassandra (tracking event archive) -----
CASSANDRA_CONTACT_POINTS=localhost:9042
CASSANDRA_KEYSPACE=tracking_events

# ----- Neo4j (route + carrier graph) -----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=freightforce

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- Kafka (shipment lifecycle events) -----
KAFKA_BROKERS=localhost:9092
KAFKA_SCHEMA_REGISTRY=http://localhost:8081

# ----- NATS JetStream (driver dispatch, sub-10ms) -----
NATS_URL=nats://localhost:4222

# ----- MQTT (IoT sensor ingest: GPS / temperature / RFID) -----
MQTT_BROKER=tcp://localhost:1883
MQTT_USERNAME=freightforce
MQTT_PASSWORD=freightforce

# ----- Object storage (MinIO — POD images, customs docs, EDI archive) -----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=freightforce

# ----- OpenTelemetry -----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAMESPACE=local

# ----- Auth (Keycloak / OIDC) -----
OIDC_ISSUER_URL=http://localhost:8080/realms/freightforce
OIDC_CLIENT_ID=freightforce
OIDC_CLIENT_SECRET=change-me

# ----- Vault -----
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root

# ----- Feature flags (Unleash) -----
UNLEASH_URL=http://localhost:4242/api
UNLEASH_API_TOKEN=

# ----- Observability backends -----
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
LOKI_URL=http://localhost:3100
JAEGER_URL=http://localhost:16686

# ----- Routing / Geo -----
OPENROUTESERVICE_URL=http://localhost:8082/ors

# ----- EDI partner connections (overridden in prod via Vault) -----
EDI_AS2_URL=http://localhost:10080/as2
EDI_SFTP_HOST=localhost
EDI_SFTP_PORT=2222
